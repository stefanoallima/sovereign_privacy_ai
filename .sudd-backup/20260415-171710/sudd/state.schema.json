{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "default": "1.0"
    },
    "sudd_version": {
      "type": "string",
      "default": "3.3",
      "description": "SUDD framework version"
    },
    "mode": {
      "type": "string",
      "enum": [
        "green",
        "brown"
      ],
      "description": "green = vision only, brown = existing code/specs"
    },
    "autonomy": {
      "type": "string",
      "enum": [
        "full",
        "interactive"
      ],
      "default": "full",
      "description": "full = auto-create prereqs, interactive = ask user"
    },
    "active_change": {
      "type": [
        "string",
        "null"
      ],
      "description": "Current change ID (e.g., green_auth_01)"
    },
    "phase": {
      "type": "string",
      "enum": [
        "inception",
        "planning",
        "build",
        "validate",
        "complete"
      ],
      "default": "inception"
    },
    "retry_count": {
      "type": "integer",
      "default": 0,
      "minimum": 0
    },
    "imported_from": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "openspec",
        "superpowers",
        null
      ],
      "description": "Source framework if ported"
    },
    "stats": {
      "type": "object",
      "properties": {
        "tasks_completed": {
          "type": "integer",
          "default": 0
        },
        "tasks_stuck": {
          "type": "integer",
          "default": 0
        },
        "tasks_blocked": {
          "type": "integer",
          "default": 0
        },
        "total_retries": {
          "type": "integer",
          "default": 0
        }
      }
    },
    "last_command": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_run": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "tests_passed": {
      "type": "boolean",
      "default": false,
      "description": "Set to true by /sudd:test when all tests pass"
    },
    "gate_score": {
      "type": "integer",
      "default": 0,
      "minimum": 0,
      "maximum": 100,
      "description": "Minimum consumer score from /sudd:gate"
    },
    "gate_passed": {
      "type": "boolean",
      "default": false,
      "description": "Set to true by /sudd:gate when all consumers >= 98 EXEMPLARY"
    },
    "total_tokens_used": {
      "type": "number",
      "default": 0,
      "description": "Cumulative tokens spent across all tasks in this change. Sum of all task_progress.*.tokens_used."
    },
    "task_progress": {
      "type": "object",
      "description": "Per-task execution tracking keyed by task ID",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in_progress",
              "validated",
              "blocked_dependency",
              "blocked_failed",
              "user_input_required"
            ],
            "default": "pending",
            "description": "Current execution status of this task"
          },
          "retries": {
            "type": "integer",
            "default": 0,
            "minimum": 0,
            "description": "Number of retry attempts for this task"
          },
          "tokens_used": {
            "type": "number",
            "default": 0,
            "description": "Cumulative tokens spent on this task across all dispatches"
          },
          "start_time": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when task execution started"
          },
          "user_input_file": {
            "type": "string",
            "description": "Path to user_input_required.md if task is parked"
          },
          "micro_verdict": {
            "type": "string",
            "enum": [
              "PASS",
              "FAIL"
            ],
            "description": "Micro-persona validation verdict"
          },
          "rubric_results": {
            "type": "object",
            "description": "Per-category rubric scores (contract, error_handling, edge_cases, behavioral)"
          },
          "confidence": {
            "type": "string",
            "enum": [
              "HIGH",
              "MEDIUM",
              "LOW"
            ],
            "description": "Agent confidence in verdict"
          }
        }
      }
    }
  },
  "required": [
    "version",
    "mode",
    "autonomy",
    "phase"
  ]
}
